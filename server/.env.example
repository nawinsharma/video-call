DATABASE_URL=postgresql://postgres:postgres@localhost:5432/videocall
JWT_SECRET=your-super-secret-jwt-key-change-this
PORT=3000
BETTER_AUTH_SECRET=your-32-byte-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000
# Optional: public API URL for OpenAPI servers & clients (production e.g. https://video-call-server.nawin.xyz)
PUBLIC_API_URL=http://localhost:3000

# TURN Server Configuration
# Recommended for APK builds across different networks: configure Twilio NTS
# or a real coturn server. STUN-only fallback is not reliable behind carrier NATs.
TURN_URLS=turn:your-turn-server.com:3478?transport=udp,turn:your-turn-server.com:3478?transport=tcp,turns:your-turn-server.com:5349?transport=tcp
TURN_USERNAME=
TURN_PASSWORD=
# Alternative for coturn REST API shared-secret auth:
TURN_SECRET=your-turn-secret-key
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NTS_TTL=86400

# Expo Push Notifications (optional for dev)
EXPO_ACCESS_TOKEN=your-expo-access-token

# Registration OTP email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=VideoCall <onboarding@resend.dev>
